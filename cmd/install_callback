#!/bin/bash

PYTHON_BIN="/var/apps/python312/target/bin/python3"
WORKING_DIR="${TRIM_PKGHOME}"
VENV_DIR="${WORKING_DIR}/venv"

# 设置 HOME 为应用目录 (用于 pip 缓存等)
export HOME="${WORKING_DIR}"
# 设置 QWENPAW_WORKING_DIR 为配置目录 (用于 qwenpaw init)
export QWENPAW_WORKING_DIR="${TRIM_PKGETC}/.qwenpaw"
# 日志文件
LOG_FILE="${TRIM_PKGVAR}/qwenpaw-install.log"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "${LOG_FILE}"
}

# 错误处理函数
handle_error() {
    local exit_code=$?
    if [ "$exit_code" -eq 0 ]; then exit_code=1; fi
    local msg="${ERROR_MSG:-执行安装脚本出错 (Exit Code: $exit_code)}"
    
    if [ -n "${TRIM_TEMP_LOGFILE}" ]; then
        echo "${msg}" >> "${TRIM_TEMP_LOGFILE}"
    fi
    
    log_msg "❌ ${msg}"
    exit 1
}
trap 'handle_error' ERR

# 确保配置目录权限正确，否则 qwenpaw init 会失败
chown -R "${TRIM_USERNAME}:${TRIM_GROUPNAME}" "${WORKING_DIR}"
chown -R "${TRIM_USERNAME}:${TRIM_GROUPNAME}" "${TRIM_PKGVAR}"
chown -R "${TRIM_USERNAME}:${TRIM_GROUPNAME}" "${TRIM_PKGETC}"
chmod -R 755 "${WORKING_DIR}"
chmod -R 755 "${TRIM_PKGVAR}"
chmod -R 755 "${TRIM_PKGETC}"

MARKER="${TRIM_PKGHOME}/.qwenpaw_keep_runtime"
if [ -f "${MARKER}" ]; then
    log_msg "检测到保留运行环境标记，跳过安装，仅修正权限"
    exit 0
fi

log_msg "开始安装 QwenPaw..."

log_msg "正在创建虚拟环境..."
"${PYTHON_BIN}" -m venv "${VENV_DIR}"
log_msg "虚拟环境 ${VENV_DIR} 创建成功"
log_msg "正在设置虚拟环境权限..."
chmod -R 755 "${VENV_DIR}"
log_msg "虚拟环境 ${VENV_DIR} 权限设置成功"

log_msg "正在激活虚拟环境..."
source "${VENV_DIR}/bin/activate"
log_msg "虚拟环境激活成功"

log_msg "正在升级虚拟环境 pip..."
python3 -m pip install --upgrade pip
log_msg "虚拟环境 pip 升级成功"

PYPI_MIRROR="${wizard_pypi_mirror:-tsinghua}"
PIP_OPTS=""

if [ "$PYPI_MIRROR" = "tsinghua" ]; then
    log_msg "使用清华源安装"
    PIP_OPTS="-i https://pypi.tuna.tsinghua.edu.cn/simple"
elif [ "$PYPI_MIRROR" = "aliyun" ]; then
    log_msg "使用阿里云源安装"
    PIP_OPTS="-i https://mirrors.aliyun.com/pypi/simple/"
elif [ "$PYPI_MIRROR" = "ustc" ]; then
    log_msg "使用中科大源安装"
    PIP_OPTS="-i https://pypi.mirrors.ustc.edu.cn/simple/"
fi

log_msg "正在安装 QwenPaw..."
PIP_LOG=$(mktemp)
if ! pip3 install qwenpaw $PIP_OPTS > "${PIP_LOG}" 2>&1; then
    cat "${PIP_LOG}" >> "${LOG_FILE}"
    ERROR_MSG=$(tail -n 1 "${PIP_LOG}")
    rm -f "${PIP_LOG}"
    handle_error
fi
cat "${PIP_LOG}" >> "${LOG_FILE}"
rm -f "${PIP_LOG}"

log_msg "正在安装 QwenPaw[ollama]..."
PIP_LOG=$(mktemp)
if ! pip3 install 'qwenpaw[ollama]' $PIP_OPTS > "${PIP_LOG}" 2>&1; then
    cat "${PIP_LOG}" >> "${LOG_FILE}"
    ERROR_MSG=$(tail -n 1 "${PIP_LOG}")
    rm -f "${PIP_LOG}"
    handle_error
fi
cat "${PIP_LOG}" >> "${LOG_FILE}"
rm -f "${PIP_LOG}"

log_msg "正在初始化 QwenPaw..."
echo "Yes" | python3 -m qwenpaw init --defaults

log_msg "正在安装 playwright..."
PIP_LOG=$(mktemp)
if ! pip3 install playwright $PIP_OPTS > "${PIP_LOG}" 2>&1; then
    cat "${PIP_LOG}" >> "${LOG_FILE}"
    ERROR_MSG=$(tail -n 1 "${PIP_LOG}")
    rm -f "${PIP_LOG}"
    handle_error
fi
cat "${PIP_LOG}" >> "${LOG_FILE}"
rm -f "${PIP_LOG}"

# 修改 playwright 镜像源为 npmmirror
PATCH_SCRIPT="${TRIM_APPDEST}/qwenpaw/patch_playwright.py"
if [ -f "${PATCH_SCRIPT}" ]; then
    log_msg "正在修改 playwright 镜像源为 npmmirror..."
    python3 "${PATCH_SCRIPT}"
else
    log_msg "⚠️ 未找到 patch_playwright.py，跳过镜像源修改"
fi

log_msg "playwright 镜像源已修改为 npmmirror，设置权限"

log_msg "正在安装 playwright chromium 浏览器..."
playwright install chromium
log_msg "playwright chromium 浏览器安装成功"

chown -R "${TRIM_USERNAME}:${TRIM_GROUPNAME}" "${WORKING_DIR}"
chown -R "${TRIM_USERNAME}:${TRIM_GROUPNAME}" "${TRIM_PKGVAR}"
chown -R "${TRIM_USERNAME}:${TRIM_GROUPNAME}" "${TRIM_PKGETC}"
chmod -R 755 "${WORKING_DIR}"
chmod -R 755 "${TRIM_PKGVAR}"
chmod -R 755 "${TRIM_PKGETC}"

log_msg "QwenPaw 安装成功！"
exit 0
