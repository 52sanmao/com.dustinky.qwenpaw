#!/bin/bash

# 错误处理
handle_error() {
    local exit_code=$?
    if [ "$exit_code" -eq 0 ]; then exit_code=1; fi
    local msg="执行卸载脚本出错 (Exit Code: $exit_code)"
    if [ -n "${TRIM_TEMP_LOGFILE}" ]; then
        echo "${msg}" >> "${TRIM_TEMP_LOGFILE}"
    fi
    exit 1
}
trap 'handle_error' ERR

# 停止服务 (保险起见，虽然系统可能已经停止了)
PID_FILE="${TRIM_PKGVAR}/qwenpaw.pid"
if [ -f "${PID_FILE}" ]; then
    pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
    if kill -0 "${pid}" 2>/dev/null; then
        kill -TERM "${pid}"
        sleep 2
        kill -KILL "${pid}" 2>/dev/null
    fi
    rm -f "${PID_FILE}"
fi

# 根据用户选择决定是否删除 TRIM_PKGHOME (运行环境/应用代码)
KEEP_RUNTIME="${wizard_keep_runtime:-false}"
if [ "$KEEP_RUNTIME" != "true" ]; then
    if [ -d "${TRIM_PKGHOME}" ]; then
        rm -rf "${TRIM_PKGHOME}"
    fi
else
    echo "保留运行环境"
    if [ -d "${TRIM_PKGHOME}" ]; then
        printf "%s\n" "$(date '+%Y-%m-%d %H:%M:%S')" > "${TRIM_PKGHOME}/.qwenpaw_keep_runtime"
    fi
fi

# 始终删除 TRIM_PKGVAR (运行时数据/日志/PID)
if [ -d "${TRIM_PKGVAR}" ]; then
    rm -rf "${TRIM_PKGVAR}"
fi

# 根据用户选择决定是否删除 TRIM_PKGETC (配置/Skills/会话)
KEEP_CONFIG="${wizard_keep_config:-true}"

if [ "$KEEP_CONFIG" != "true" ]; then
    if [ -d "${TRIM_PKGETC}" ]; then
        rm -rf "${TRIM_PKGETC}"
    fi
    echo "QwenPaw 已完全卸载 (包括配置文件)"
else
    echo "QwenPaw 已卸载 (保留配置文件)"
fi

exit 0
